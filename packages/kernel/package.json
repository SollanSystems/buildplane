{
	"name": "@buildplane/kernel",
	"private": true,
	"version": "0.4.2",
	"type": "module",
	"description": "Core units, scheduler, and orchestration primitives for Buildplane",
	"exports": {
		".": {
			"source": "./src/index.ts",
			"types": "./src/index.d.ts",
			"import": "./dist/index.js"
		},
		"./source": {
			"source": "./src/index.ts",
			"types": "./src/index.d.ts",
			"import": "./dist/index.js"
		},
		"./packet": {
			"types": "./dist/packet.d.ts",
			"import": "./dist/packet.js"
		},
		"./ports": {
			"types": "./dist/ports.d.ts",
			"import": "./dist/ports.js"
		},
		"./run-loop": {
			"types": "./dist/run-loop.d.ts",
			"import": "./dist/run-loop.js"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"import": "./dist/types.js"
		},
		"./events": {
			"types": "./dist/events.d.ts",
			"import": "./dist/events.js"
		}
	},
	"dependencies": {
		"@buildplane/capability-broker": "workspace:*"
	}
}
