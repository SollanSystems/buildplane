{
	"id": "strat-smoke-001",
	"mode": "implement-then-review",
	"mergePolicy": "reviewer-must-approve",
	"children": [
		{
			"role": "implementer",
			"packet": {
				"unit": {
					"id": "impl-001",
					"kind": "command",
					"scope": "task",
					"inputRefs": [],
					"expectedOutputs": ["output.txt"],
					"verificationContract": "exit-0-and-required-outputs",
					"policyProfile": "default"
				},
				"execution": {
					"command": "sh",
					"args": ["-c", "echo 'Hello from implementer' > output.txt"]
				},
				"verification": {
					"requiredOutputs": ["output.txt"]
				}
			}
		},
		{
			"role": "reviewer",
			"dependsOn": ["impl-001"],
			"packet": {
				"unit": {
					"id": "review-001",
					"kind": "command",
					"scope": "task",
					"inputRefs": ["output.txt"],
					"expectedOutputs": [],
					"verificationContract": "exit-0-and-required-outputs",
					"policyProfile": "default"
				},
				"execution": {
					"command": "sh",
					"args": ["-c", "test -f output.txt && echo 'Review: APPROVED'"]
				},
				"verification": {
					"requiredOutputs": []
				}
			}
		}
	]
}
